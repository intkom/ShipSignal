# App URL — used for metadata, sitemap, robots, emails (defaults to https://bullhorn.to)
NEXT_PUBLIC_APP_URL=https://your-domain.com

# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API key HMAC secret — used to hash API keys for storage (recommended)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, falls back to plain SHA-256 hashing.
API_KEY_HMAC_SECRET=

# Sentry (recommended)
SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Upstash Redis — rate limiting (recommended, optional)
# If not configured, an in-memory rate limiter is used as fallback.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Google OAuth — iOS Capacitor (optional, for iOS dev only)
GOOGLE_IOS_CLIENT_ID=
GOOGLE_WEB_CLIENT_ID=

# Push Notifications (VAPID keys) - generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Twitter/X API — platform publishing (optional)
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn API — platform publishing (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Reddit API — platform publishing (optional)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=web:bullhorn-scheduler:v1.0.0 (by /u/your-reddit-username)

# Cron jobs — secret for authenticated cron endpoints (required in production)
CRON_SECRET=

# Email notifications — Resend (optional)
RESEND_API_KEY=
RESEND_FROM_EMAIL=YourApp <notifications@your-domain.com>

# Web Push VAPID contact (defaults to mailto:hello@bullhorn.to)
VAPID_SUBJECT=mailto:you@your-domain.com

# APNs — iOS push notifications (optional, for iOS builds only)
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_AUTH_KEY=
APNS_BUNDLE_ID=com.your-org.your-app
APNS_ENVIRONMENT=sandbox

# iOS build — Fastlane / App Store Connect (optional, for iOS contributors only)
ASC_KEY_ID=
ASC_ISSUER_ID=
