{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-playwright"]
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@anthropic-ai/mcp-github"]
    },
    "supabase": {
      "command": "doppler",
      "args": [
        "run",
        "--project",
        "bullhorn",
        "--config",
        "dev",
        "--",
        "npx",
        "-y",
        "@supabase/mcp-server-supabase@latest"
      ],
      "env": {
        "SUPABASE_PROJECT_REF": "<your-supabase-project-ref>"
      }
    },
    "bullhorn": {
      "command": "doppler",
      "args": ["run", "--project", "bullhorn", "--config", "prd", "--", "npx", "-y", "@mean-weasel/bullhorn-mcp"],
      "env": {
        "BULLHORN_API_URL": "https://bullhorn.to"
      }
    }
  }
}
