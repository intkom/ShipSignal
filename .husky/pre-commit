#!/bin/bash
# Git pre-commit hook: run lint, typecheck, and unit tests before allowing commits.

set -e

BLUE='\033[34m'
GREEN='\033[32m'
RED='\033[31m'
RESET='\033[0m'

echo -e "${BLUE}Running pre-commit checks...${RESET}"

# Lint (only staged .ts/.tsx files, fail on errors only — not warnings)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM -- '*.ts' '*.tsx' | grep -v node_modules || true)
if [ -n "$STAGED_FILES" ]; then
  echo -e "${BLUE}  ESLint (staged files)...${RESET}"
  npx eslint --quiet $STAGED_FILES || {
    echo -e "${RED}✗ ESLint found errors in staged files. Fix them before committing.${RESET}"
    exit 1
  }
else
  echo -e "${BLUE}  ESLint — no staged .ts/.tsx files, skipping.${RESET}"
fi

# Typecheck
echo -e "${BLUE}  TypeScript...${RESET}"
npm run typecheck --silent || {
  echo -e "${RED}✗ Type checking failed. Fix errors before committing.${RESET}"
  exit 1
}

# Unit tests
echo -e "${BLUE}  Unit tests...${RESET}"
npx vitest run --reporter=dot 2>/dev/null || {
  echo -e "${RED}✗ Tests failed. Fix failures before committing.${RESET}"
  exit 1
}

# Format check (only staged files)
if [ -n "$STAGED_FILES" ]; then
  echo -e "${BLUE}  Prettier (staged files)...${RESET}"
  npx prettier --check $STAGED_FILES || {
    echo -e "${RED}✗ Unformatted staged files found. Run 'make fix' then re-stage.${RESET}"
    exit 1
  }
fi

echo -e "${GREEN}✓ All pre-commit checks passed!${RESET}"
