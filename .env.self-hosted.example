# Bullhorn Self-Hosted — App Environment Variables
# Copy to .env.local: cp .env.self-hosted.example .env.local

# --- Self-hosted mode ---
SELF_HOSTED=true

# --- Supabase (local Docker) ---
# Update these after running: make self-host-init
NEXT_PUBLIC_SUPABASE_URL=http://localhost:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste-anon-key-from-docker-setup>
SUPABASE_SERVICE_ROLE_KEY=<paste-service-role-key-from-docker-setup>

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
CRON_SECRET=<generate-with: openssl rand -base64 32>

# --- Twitter / X ---
# Create app at: https://developer.x.com/en/portal/dashboard
# Enable OAuth 2.0, set callback URL to: http://localhost:3000/api/social-accounts/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# --- LinkedIn ---
# Create app at: https://www.linkedin.com/developers/apps
# Request "Share on LinkedIn" + "Sign In with LinkedIn using OpenID Connect"
# Set redirect URL to: http://localhost:3000/api/social-accounts/linkedin/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# --- Reddit ---
# Create "script" app at: https://www.reddit.com/prefs/apps
# Set redirect URI to http://localhost:3000 (required by Reddit, unused for script auth)
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=your-reddit-username
REDDIT_PASSWORD=your-reddit-password
REDDIT_USER_AGENT=web:bullhorn-scheduler:v1.0.0 (by /u/your-username)

# --- Optional ---
# UPSTASH_REDIS_REST_URL=    # Rate limiting (optional for self-hosted)
# UPSTASH_REDIS_REST_TOKEN=  # Rate limiting (optional for self-hosted)
# NEXT_PUBLIC_SENTRY_DSN=    # Error monitoring (optional)
